+++ b/agent/claude_stream_runtime.py
@@ -0,0 +1,105 @@
+"""Claude Code stream-json runtime path (P1: turn round-trip).
+
+Mirror of ``agent/codex_runtime.run_codex_app_server_turn`` for the Claude Code
+provider. When ``agent.api_mode == "claude_stream"`` (opt-in via
+``model.claude_runtime: stream_session``), ``run_conversation()`` hands the turn
+to a persistent ``ClaudeStreamSession`` instead of the chat_completions loop.
+
+P1 scope: round-trip a turn through the session and project the final assistant
+text back into Hermes' messages. **On any failure it degrades to the
+chat_completions path (the local shim) — never hard-breaks a turn.** Richer
+event mapping (P2), the Hermes-tools-over-MCP bridge (P3), and the
+permission/approval bridge (P4) are deliberately out of scope here.
+"""
+from __future__ import annotations
+
+import logging
+from typing import Any, Dict, List
+
+logger = logging.getLogger(__name__)
+
+
+def _resolve_cwd(agent) -> str:
+    cwd = getattr(agent, "session_cwd", None)
+    if cwd:
+        return str(cwd)
+    try:
+        from agent.runtime_cwd import resolve_agent_cwd
+        return str(resolve_agent_cwd())
+    except Exception:
+        import pathlib
+        return str(pathlib.Path.cwd())
+
+
+def run_claude_stream_turn(
+    agent,
+    *,
+    user_message: str,
+    original_user_message: Any,
+    messages: List[Dict[str, Any]],
+    effective_task_id: str,
+    should_review_memory: bool = False,
+) -> Dict[str, Any] | None:
+    """Run one turn through the persistent Claude Code stream-json session.
+
+    Returns the standard run_conversation() result dict on success, or **None**
+    on failure — in which case ``agent.api_mode`` has been reset to
+    ``chat_completions`` so the caller falls through to the shim path.
+    """
+    try:
+        from agent.transports.claude_stream_session import ClaudeStreamSession
+    except Exception as exc:  # import failure → fall back immediately
+        logger.warning("claude_stream unavailable (%s); falling back to chat_completions", exc)
+        agent.api_mode = "chat_completions"
+        return None
+
+    try:
+        # Lazy session: one ClaudeStreamSession per AIAgent, reused across turns.
+        if getattr(agent, "_claude_stream_session", None) is None:
+            model = (getattr(agent, "model", None) or "sonnet")
+            agent._claude_stream_session = ClaudeStreamSession(
+                cwd=_resolve_cwd(agent), model=model,
+            )
+
+        # The user message is ALREADY appended to `messages` by run_conversation()
+        # before this early-return path; do NOT append it again.
+        turn = agent._claude_stream_session.send(user_message)
+        if turn.is_error:
+            raise RuntimeError(turn.error or "claude_stream turn error")
+
+        # P1: project the final assistant text. (P2 projects tool steps too.)
+        messages.append({"role": "assistant", "content": turn.text})
+
+        # Best-effort external-memory sync, mirroring the codex path.
+        if should_review_memory and turn.text:
+            try:
+                agent._sync_external_memory_for_turn(
+                    original_user_message=original_user_message,
+                    final_response=turn.text,
+                    interrupted=False,
+                    messages=messages,
+                )
+            except Exception:
+                logger.debug("claude_stream external memory sync raised", exc_info=True)
+
+        return {
+            "final_response": turn.text,
+            "messages": messages,
+            "api_calls": 1,
+            "completed": True,
+        }
+
+    except Exception as exc:
+        logger.warning(
+            "claude_stream turn failed (%s); degrading to chat_completions (shim) for this session",
+            exc,
+        )
+        # Retire the (possibly wedged) session and fall back to the shim.
+        try:
+            if getattr(agent, "_claude_stream_session", None):
+                agent._claude_stream_session.close()
+        except Exception:
+            pass
+        agent._claude_stream_session = None
+        agent.api_mode = "chat_completions"
+        return None
