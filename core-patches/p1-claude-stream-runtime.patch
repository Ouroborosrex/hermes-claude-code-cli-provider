diff --git a/agent/transports/claude_stream_session.py b/agent/transports/claude_stream_session.py
new file mode 100644
index 000000000..331421d5c
--- /dev/null
+++ b/agent/transports/claude_stream_session.py
@@ -0,0 +1,167 @@
+"""Persistent Claude Code session over the stream-json protocol.
+
+One long-lived ``claude --input-format stream-json --output-format stream-json``
+process driven turn-by-turn — the Claude analog of
+``agent/transports/codex_app_server_session.py``. Context persists across turns
+because it's the same process; each ``send()`` blocks until that turn's
+``result`` event.
+
+This is the **P1** transport (issue: core integration plan): it captures the
+final text + usage and is enough for the turn round-trip. Richer event→Hermes
+mapping (streamed tool steps), the Hermes-tools-over-MCP bridge, and the
+permission/approval bridge are P2–P4 and deliberately not here.
+
+Subscription-billed (no API key), same as ``claude -p``.
+"""
+from __future__ import annotations
+
+import json
+import logging
+import os
+import pathlib
+import shutil
+import subprocess
+import time
+from dataclasses import dataclass, field
+from typing import Optional
+
+logger = logging.getLogger(__name__)
+
+# Pre-approved in engine/stream mode so `claude` runs tools without an
+# interactive permission prompt (it can't prompt in -p mode). The
+# permission/approval bridge that replaces blanket pre-approval is P4.
+DEFAULT_STREAM_TOOLS = "Read,Write,Edit,Bash,Glob,Grep,WebFetch,WebSearch,TodoWrite"
+
+
+@dataclass
+class StreamTurn:
+    """Result of one user turn."""
+    text: str = ""
+    tool_uses: list[str] = field(default_factory=list)
+    tool_results: int = 0
+    usage: Optional[dict] = None
+    cost_usd: Optional[float] = None
+    session_id: Optional[str] = None
+    is_error: bool = False
+    error: Optional[str] = None
+
+
+class ClaudeStreamSession:
+    """One persistent `claude` stream-json process. Reused across turns."""
+
+    def __init__(
+        self,
+        cwd: Optional[str] = None,
+        model: str = "sonnet",
+        tools: Optional[str] = None,
+        permission_mode: str = "acceptEdits",
+        bin_: Optional[str] = None,
+        mcp_config: Optional[str] = None,
+    ) -> None:
+        self.bin = (
+            bin_
+            or os.environ.get("CLAUDE_CODE_CLI_BIN")
+            or shutil.which("claude")
+            or "/usr/bin/claude"
+        )
+        self.cwd = str(pathlib.Path(cwd).expanduser()) if cwd else str(pathlib.Path.cwd())
+        self.model = model or "sonnet"
+        argv = [
+            self.bin, "-p",
+            "--input-format", "stream-json",
+            "--output-format", "stream-json",
+            "--verbose",  # required for stream-json output in -p mode
+            "--model", self.model,
+            "--permission-mode", permission_mode,
+            "--allowedTools", tools or os.environ.get("CLAUDE_CODE_CLI_ENGINE_TOOLS", DEFAULT_STREAM_TOOLS),
+            "--no-session-persistence",
+        ]
+        # P3 hook: register Hermes' tools/skills as an MCP server so the agent
+        # can call them. Inert until a config path is supplied.
+        if mcp_config:
+            argv += ["--mcp-config", mcp_config, "--strict-mcp-config"]
+        self._proc = subprocess.Popen(
+            argv, cwd=self.cwd,
+            stdin=subprocess.PIPE, stdout=subprocess.PIPE, stderr=subprocess.PIPE,
+            text=True, encoding="utf-8", errors="replace", bufsize=1,
+        )
+        self.session_id: Optional[str] = None
+        logger.info("claude_stream: spawned session (model=%s cwd=%s)", self.model, self.cwd)
+
+    @property
+    def alive(self) -> bool:
+        return self._proc.poll() is None
+
+    def send(self, text: str, turn_timeout: float = 900.0) -> StreamTurn:
+        """Send one user turn; block until that turn's `result` event."""
+        turn = StreamTurn()
+        if self._proc.poll() is not None:
+            turn.is_error = True
+            turn.error = f"session dead (claude exited {self._proc.returncode})"
+            turn.text = f"[{turn.error}]"
+            return turn
+        try:
+            self._proc.stdin.write(  # type: ignore[union-attr]
+                json.dumps({"type": "user", "message": {"role": "user", "content": text}}) + "\n"
+            )
+            self._proc.stdin.flush()  # type: ignore[union-attr]
+        except (BrokenPipeError, ValueError) as exc:
+            turn.is_error = True
+            turn.error = f"session stdin closed: {exc!r}"
+            turn.text = f"[{turn.error}]"
+            return turn
+
+        deadline = time.time() + turn_timeout
+        for line in self._proc.stdout:  # type: ignore[union-attr]
+            line = line.strip()
+            if not line:
+                continue
+            try:
+                ev = json.loads(line)
+            except json.JSONDecodeError:
+                continue
+            t, sub = ev.get("type"), ev.get("subtype")
+            if t == "system" and sub == "init":
+                self.session_id = ev.get("session_id") or self.session_id
+            elif t == "assistant":
+                for b in (ev.get("message") or {}).get("content") or []:
+                    if isinstance(b, dict) and b.get("type") == "tool_use":
+                        turn.tool_uses.append(b.get("name", "?"))
+            elif t == "user":
+                for b in (ev.get("message") or {}).get("content") or []:
+                    if isinstance(b, dict) and b.get("type") == "tool_result":
+                        turn.tool_results += 1
+            elif t == "result":
+                turn.text = ev.get("result") or ""
+                turn.usage = ev.get("usage")
+                turn.cost_usd = ev.get("total_cost_usd")
+                turn.session_id = ev.get("session_id") or self.session_id
+                turn.is_error = bool(ev.get("is_error"))
+                if turn.is_error:
+                    turn.error = "claude reported is_error"
+                return turn
+            if time.time() > deadline:
+                turn.is_error = True
+                turn.error = f"turn timed out after {turn_timeout}s"
+                turn.text = f"[{turn.error}]"
+                return turn
+
+        # stdout closed without a result → process died mid-turn
+        turn.is_error = True
+        turn.error = turn.error or "session ended without a result event"
+        turn.text = turn.text or f"[{turn.error}]"
+        return turn
+
+    def close(self) -> None:
+        try:
+            if self._proc.stdin:
+                self._proc.stdin.close()
+        except Exception:
+            pass
+        try:
+            self._proc.wait(timeout=10)
+        except Exception:
+            try:
+                self._proc.kill()
+            except Exception:
+                pass
