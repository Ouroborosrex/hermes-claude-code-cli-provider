+# Provider names eligible for the Claude Code stream-json runtime.
+_CLAUDE_STREAM_PROVIDERS = {
+    "claude-code-cli", "claude-cli", "cc-cli", "claude-code-local",
+}
+
+
+def _maybe_apply_claude_stream_runtime(
+    *,
+    provider: str,
+    api_mode: str,
+    model_cfg: Optional[Dict[str, Any]],
+) -> str:
+    """Optional opt-in: rewrite api_mode → "claude_stream" for the Claude Code
+    CLI provider when the user has explicitly enabled it via
+    `model.claude_runtime: stream_session` in config.yaml.
+
+    Default behavior is preserved: when the key is unset, "auto", or empty —
+    or the provider isn't claude-code-cli — this is a no-op. Returns the
+    (possibly-rewritten) api_mode."""
+    if not model_cfg:
+        return api_mode
+    if provider not in _CLAUDE_STREAM_PROVIDERS:
+        return api_mode
+    runtime = str(model_cfg.get("claude_runtime") or "").strip().lower()
+    if runtime == "stream_session":
+        return "claude_stream"
+    return api_mode
+
+
